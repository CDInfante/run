{
  "name": "run-cdinfante",
  "private": true,
  "version": "1.3.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "biome check .",
    "format": "biome format --write .",
    "preview": "vite preview",
    "scrape:amenities": "tsx scripts/scrape-amenities.ts",
    "scrape:ships": "tsx scripts/scrape-ships.ts",
    "scrape:trails": "tsx scripts/scrape-trails.ts",
    "scrape:marine": "tsx scripts/scrape-marine.ts",
    "scrape:all": "npm run scrape:amenities && npm run scrape:ships && npm run scrape:trails && npm run scrape:marine"
  },
  "dependencies": {
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/typography": "^0.5.19",
    "@tanstack/react-query": "^5.96.2",
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "leaflet.markercluster": "^1.5.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-leaflet-cluster": "^4.1.3",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@playwright/browser-chromium": "^1.59.1",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/vite": "^4.0.9",
    "@types/leaflet": "^1.9.16",
    "@types/node": "^22.19.17",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.20",
    "axios": "^1.8.1",
    "axios-retry": "^4.5.0",
    "cheerio": "^1.2.0",
    "date-fns": "^4.1.0",
    "globals": "^17.4.0",
    "leaflet": "^1.9.4",
    "lucide-react": "^1.7.0",
    "postcss": "^8.5.3",
    "react-leaflet": "^5.0.0",
    "tailwindcss": "^4.0.9",
    "tsx": "^4.7.1",
    "typescript": "~6.0.2",
    "vite": "^8.0.5",
    "vite-plugin-pwa": "^1.2.0"
  },
  "overrides": {
    "serialize-javascript": "latest",
    "vite-plugin-pwa": {
      "vite": "$vite"
    },
    "sourcemap-codec": "npm:@jridgewell/sourcemap-codec@latest",
    "source-map": "latest",
    "glob": "latest"
  }
}
